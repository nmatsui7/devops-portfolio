{
  "dashboard": {
    "title": "Portfolio App Local Overview",
    "tags": ["portfolio", "local-demo"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Scrape Health",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"portfolio-app-local\"}"
          }
        ]
      },
      {
        "title": "Readiness",
        "type": "stat",
        "targets": [
          {
            "expr": "portfolio_app_ready"
          }
        ]
      },
      {
        "title": "App Info",
        "type": "stat",
        "targets": [
          {
            "expr": "portfolio_app_info"
          }
        ]
      }
    ]
  }
}
